# Copy to .env.local and fill in from your Supabase project (Project Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only secret. Never prefix with NEXT_PUBLIC. Used for admin tasks later.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Canonical public URL of the site. Set this in production so auth/OAuth redirect
# links can't be poisoned via a spoofed Host header. Locally, http://localhost:3000.
NEXT_PUBLIC_SITE_URL=https://your-domain.com
